# Porta HTTP da aplicação
PORT=3000

# Usuário administrador (criado automaticamente na primeira execução)
ADMIN_USER=admin
ADMIN_PASSWORD=trocar-senha-segura

# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=trocar-por-string-aleatoria-longa

# Horário do backup diário (formato HH:MM, fuso do servidor)
BACKUP_TIME=02:00

# Caminho do banco SQLite com os metadados da aplicação
DB_PATH=data/app.db

# Armazenamento S3 dos backups
# AWS S3: deixe S3_ENDPOINT em branco e defina S3_REGION (ex: us-east-1)
# Cloudflare R2: S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# MinIO próprio: S3_ENDPOINT=https://minio.exemplo.com
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=pg-backups
